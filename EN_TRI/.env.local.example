# ============================================
# PROVIDERS IA — Clés API (variables d'environnement)
# ============================================
# Ces variables sont chargées côté serveur.
# NE JAMAIS commit ce fichier (déjà dans .gitignore).
# ============================================

# Z.ai (abonnement Coding Plan)
PROVIDER_ZAI_KEY=votre_cle_z_ai_ici

# Groq (gratuit, https://console.groq.com/keys)
PROVIDER_GROQ_KEY=

# OpenRouter (https://openrouter.ai/keys)
PROVIDER_OPENROUTER_KEY=

# OpenAI (https://platform.openai.com/api-keys)
PROVIDER_OPENAI_KEY=

# Hugging Face (https://huggingface.co/settings/tokens)
PROVIDER_HF_KEY=

# Google Gemini (https://aistudio.google.com/app/apikey)
PROVIDER_GEMINI_KEY=
